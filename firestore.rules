rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: username, email, avatarUrl, level, coins, diamonds, isVerified, isBanned, createdAt
    //
    // Collection: rooms
    // Fields: ownerId, name, description, coverUrl, type, maxSeats, isLive, memberCount, createdAt
    //
    // Collection: rooms/{roomId}/messages
    // Fields: roomId, userId, username, content, type, timestamp
    //
    // Collection: rooms/{roomId}/seats
    // Fields: userId, isLocked, isMuted
    //
    // Collection: conversations
    // Fields: participants, lastMessage, lastMessageAt, unreadCount
    //
    // Collection: conversations/{conversationId}/messages
    // Fields: senderId, content, timestamp, read
    //
    // Collection: follows
    // Fields: followerId, followingId, createdAt
    //
    // Collection: posts
    // Fields: userId, username, avatarUrl, content, imageUrl, likes, createdAt
    //
    // Collection: notifications
    // Fields: userId, type, title, message, data, read, createdAt
    //
    // Collection: pk_challenges
    // Fields: roomId, user1Id, user2Id, user1Points, user2Points, status, winnerId, duration, startedAt, endsAt
    //
    // Collection: lucky_boxes
    // Fields: roomId, creatorId, totalAmount, remainingAmount, totalWinners, winners, status, createdAt
    //
    // Collection: vip_subscriptions
    // Fields: userId, tier, startedAt, expiresAt, perks
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          request.auth.token.email == "sayed.fayhi@gmail.com" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isValidUser(data) {
      return data.username is string && data.username.size() >= 2 &&
             data.email is string;
    }

    function isRoomOwner(roomId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/rooms/$(roomId)) &&
             get(/databases/$(database)/documents/rooms/$(roomId)).data.ownerId == request.auth.uid;
    }

    function isValidMember(data) {
      return data.userId is string && 
             data.username is string &&
             data.isActive is bool &&
             (!('avatarUrl' in data) || data.avatarUrl is string) &&
             (!('joinedAt' in data) || data.joinedAt is string);
    }

    function isValidSeat(data) {
      return (!('userId' in data) || (data.userId == null || data.userId is string)) &&
             (!('joinedAt' in data) || (data.joinedAt == null || data.joinedAt is string)) &&
             (!('isLocked' in data) || data.isLocked is bool) &&
             (!('isMuted' in data) || data.isMuted is bool);
    }

    function isValidRoom(data) {
      return data.name is string && data.name.size() > 0 &&
             data.ownerId is string &&
             data.type in ['public', 'private', 'vip'] &&
             (!('announcement' in data) || data.announcement is string) &&
             (!('bannedUsers' in data) || data.bannedUsers is list);
    }

    function isValidNotification(data) {
      return data.userId is string &&
             data.type in ['private_message', 'room_announcement', 'gift_arrival', 'system'] &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 500 &&
             data.read is bool &&
             data.createdAt is string;
    }

    function isValidPK(data) {
      return data.roomId is string &&
             data.user1Id is string &&
             data.user2Id is string &&
             data.user1Points is int &&
             data.user2Points is int &&
             data.status in ['active', 'completed'] &&
             data.startedAt is string &&
             data.endsAt is string;
    }

    function isValidLuckyBox(data) {
      return data.roomId is string &&
             data.creatorId is string &&
             data.totalAmount is int &&
             data.remainingAmount is int &&
             data.totalWinners is int &&
             data.winners is list &&
             data.status in ['active', 'distributed'] &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.token.email == "sayed.fayhi@gmail.com";
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (
        (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) || 
        isAdmin()
      );

      match /tasks/{taskId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRoom(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());

      match /messages/{msgId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      }

      match /seats/{seatNum} {
        allow read: if isAuthenticated();
        // Allow owner to update any seat (lock/mute/kick)
        // Allow user to update their own seat (take/leave)
        allow update: if isAuthenticated() && isValidSeat(request.resource.data) && (
          isRoomOwner(roomId) ||
          (request.resource.data.userId == request.auth.uid && (resource == null || !('userId' in resource.data) || resource.data.userId == null)) ||
          (resource != null && resource.data.userId == request.auth.uid && (!('userId' in request.resource.data) || request.resource.data.userId == null))
        );
      }

      match /members/{memberId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isOwner(memberId) && isValidMember(request.resource.data);
        allow update: if isAuthenticated() && (isOwner(memberId) || isRoomOwner(roomId)) && isValidMember(request.resource.data);
        allow delete: if isAuthenticated() && (isOwner(memberId) || isRoomOwner(roomId));
      }
    }

    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants && request.resource.data.senderId == request.auth.uid;
      }
    }

    match /follows/{followId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.followerId == request.auth.uid;
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /store_items/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /gifts/{giftId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /pk_challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isRoomOwner(request.resource.data.roomId) && isValidPK(request.resource.data);
      allow update: if isAuthenticated(); // Points are updated by gift service
    }

    match /lucky_boxes/{boxId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidLuckyBox(request.resource.data) && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAuthenticated(); // Winners are added when claiming
    }

    match /vip_subscriptions/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /daily_quests/{questId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
